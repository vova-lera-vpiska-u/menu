{
  "name": "menu",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:frontend": "pnpm --filter @menu/frontend dev",
    "dev:backend": "pnpm --filter @menu/backend dev",
    "build": "pnpm --filter \"./apps/*\" build",
    "build:frontend": "pnpm --filter @menu/frontend build",
    "build:backend": "pnpm --filter @menu/backend build",
    "lint": "pnpm --filter \"./apps/*\" lint"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
